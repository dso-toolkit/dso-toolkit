{
  "name": "dso-storybook",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "storybook dev --port 45000",
    "storybook:build": "storybook build --output-dir ./www && tsx scripts/postbuild-transform.ts",
    "e2e": "start-server-and-test 'pnpm e2e:start' http-get://127.0.0.1:45000 'pnpm e2e:test'",
    "e2e:start": "http-server --silent --port 45000 www",
    "e2e:test": "cypress run",
    "prepare": "cypress install"
  },
  "dependencies": {
    "@dso-toolkit/core": "workspace:*",
    "@iframe-resizer/child": "catalog:",
    "@simonsmith/cypress-image-snapshot": "^10.0.4",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/builder-vite": "catalog:storybook",
    "@storybook/web-components-vite": "catalog:storybook",
    "@types/lodash.startcase": "catalog:",
    "axe-core": "catalog:",
    "cheerio": "^1.2.0",
    "cypress": "15.14.2",
    "cypress-axe": "^1.7.0",
    "cypress-real-events": "^1.15.0",
    "dso-toolkit": "workspace:*",
    "eslint": "catalog:",
    "http-proxy-middleware": "catalog:",
    "http-server": "^14.1.1",
    "lit-html": "catalog:",
    "lodash.startcase": "catalog:",
    "markdown-to-jsx": "catalog:",
    "start-server-and-test": "^3.0.11",
    "storybook": "catalog:storybook",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "uuid": "catalog:",
    "vite": "catalog:storybook"
  },
  "nx": {
    "includedScripts": []
  }
