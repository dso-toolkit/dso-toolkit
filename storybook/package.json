{
  "name": "dso-storybook",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "storybook dev --port 45000",
    "storybook:build": "storybook build --output-dir ./www && tsx scripts/postbuild-transform.ts",
    "e2e": "start-server-and-test 'pnpm e2e:start' http-get://127.0.0.1:45000 'pnpm e2e:test'",
    "e2e:start": "http-server --silent --port 45000 www",
    "e2e:test": "cypress run",
    "prepare": "cypress install"
  },
  "dependencies": {
    "@dso-toolkit/core": "workspace:*",
    "@iframe-resizer/child": "^5.5.9",
    "@simonsmith/cypress-image-snapshot": "^10.0.3",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/builder-vite": "10.3.5",
    "@storybook/web-components-vite": "10.3.5",
    "@types/lodash.startcase": "^4.4.9",
    "axe-core": "^4.11.3",
    "cheerio": "^1.2.0",
    "cypress": "^15.14.1",
    "cypress-axe": "^1.7.0",
    "cypress-real-events": "^1.15.0",
    "dso-toolkit": "workspace:*",
    "eslint": "^9.39.4",
    "http-proxy-middleware": "^3.0.5",
    "http-server": "^14.1.1",
    "lit-html": "^3.3.2",
    "lodash.startcase": "^4.4.0",
    "markdown-to-jsx": "^9.7.16",
    "start-server-and-test": "^3.0.2",
    "storybook": "10.3.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.10"
  },
  "nx": {
    "includedScripts": []
  }
}
