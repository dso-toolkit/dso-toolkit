{
  "name": "dso-toolkit-monorepo",
  "private": true,
  "scripts": {
    "graph": "nx graph --watch=true",
    "format": "prettier --write .",
    "lint": "pnpm lint:prettier && pnpm lint:stylelint && pnpm lint:eslint",
    "lint:prettier": "prettier --check .",
    "lint:stylelint": "stylelint '**/*.scss'",
    "lint:eslint": "eslint --max-warnings=0",
    "build": "nx run-many --target=build",
    "build-www": "nx run-many --target=build-www",
    "e2e": "pnpm --filter dso-storybook e2e",
    "release": "tsx scripts/release",
    "icons": "tsx scripts/icons",
    "clear-node-modules": "rimraf node_modules angular-workspace/node_modules angular-workspace/projects/component-library/node_modules packages/core/node_modules packages/dso-toolkit/node_modules packages/react/node_modules storybook/node_modules",
    "website": "pnpm --filter website start",
    "start": "tsx scripts/start.ts"
  },
  "dependencies": {
    "@azure/storage-file-datalake": "^12.29.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lit-labs/ssr": "^4.0.0",
    "@octokit/rest": "^22.0.1",
    "@stencil-community/eslint-plugin": "^0.10.0",
    "@types/minimist": "^1.2.5",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "cpy-cli": "^7.0.0",
    "danger": "13.0.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "minimist": "^1.2.8",
    "nx": "22.6.1",
    "plop": "^4.0.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "semver": "^7.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-scss": "^16.0.2",
    "stylelint-use-logical-spec": "^5.0.1",
    "svgo": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.4"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "webpack": "5.105.2"
    },
    "onlyBuiltDependencies": [
      "@compodoc/compodoc",
      "@parcel/watcher",
      "core-js",
      "core-js-pure",
      "cypress",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "nx"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint-plugin-storybook": "10.3.3"
  }
}
