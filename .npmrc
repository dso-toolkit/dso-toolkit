# Storybook staticDirs copies @iframe-resizer files from the workspace root node_modules.
# Without hoisting, pnpm only places packages in the node_modules of the package that declares them,
# not at the workspace root. public-hoist-pattern[] tells pnpm to additionally hoist matching
# packages to the root node_modules, making the path resolvable for Storybook.
public-hoist-pattern[]=@iframe-resizer/*

# Prevent installing packages published less than 3 days ago (4320 minutes).
# This guards against malicious packages that are quickly unpublished after a supply chain attack.
minimum-release-age=4320